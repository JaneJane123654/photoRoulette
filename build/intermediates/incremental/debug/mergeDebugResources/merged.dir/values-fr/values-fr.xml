    <string name="permission_denied_message">Photo Roulette a besoin d\'accéder à votre bibliothèque pour créer la pile aléatoire. Ouvrez les paramètres système pour autoriser l\'accès aux photos pour cette application.</string>
    <string name="permission_denied_title">L\'accès aux photos est désactivé</string>
    <string name="permission_feature_all_photos_body">Autoriser toutes les photos offre la plus grande variété de surprises dans toute votre bibliothèque.</string>
    <string name="permission_feature_all_photos_icon_description">Option toutes les photos</string>
    <string name="permission_feature_all_photos_title">Meilleur mélange avec accès complet</string>
    <string name="permission_feature_control_body">Vous pouvez revoir ce choix plus tard dans les paramètres système pour élargir ou réduire ce que l\'application peut mélanger.</string>
    <string name="permission_feature_control_icon_description">Rappel de contrôle des autorisations</string>
    <string name="permission_feature_control_title">Vous gardez le contrôle</string>
    <string name="permission_feature_selected_body">Vous préférez un ensemble réduit ? Android 14 peut limiter l\'accès aux photos ou albums choisis, et Photo Roulette respectera cette limite.</string>
    <string name="permission_feature_selected_icon_description">Option photos et albums sélectionnés</string>
    <string name="permission_feature_selected_title">Les photos sélectionnées fonctionnent aussi</string>
    <string name="permission_illustration_collection_description">Carte de collection de photos dans l\'illustration d\'autorisation</string>
    <string name="permission_illustration_library_description">Carte d\'accès photos mise en avant dans l\'illustration d\'autorisation</string>
    <string name="permission_illustration_shuffle_description">Carte de mélange dans l\'illustration d\'autorisation</string>
    <string name="permission_maybe_later">Plus tard</string>
    <string name="permission_rationale_description_primary">Photo Roulette a besoin de l\'accès aux photos pour créer une pile aléatoire depuis votre bibliothèque. Sur Android 14, vous pouvez autoriser toutes les photos pour le mélange le plus large, ou ne partager que des photos et albums sélectionnés.</string>
    <string name="permission_rationale_description_secondary">Quel que soit votre choix, c\'est valide. L\'application mélange et affiche uniquement les photos visibles par Android, et rien ne quitte votre appareil.</string>
    <string name="permission_rationale_title">Mélangez votre galerie à votre façon</string>
