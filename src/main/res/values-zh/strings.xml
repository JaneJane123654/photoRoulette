    <string name="default_behavior_visibility_auto_hidden_description">本月已出现满 5 次，当前为自动关闭状态。下个月会自动恢复开启。</string>
    <string name="default_behavior_visibility_user_hidden_description">你已手动关闭。下个月也会保持关闭，需手动重新开启。</string>

